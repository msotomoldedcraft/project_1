{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/login.css') }}">
{% endblock %}

{% block body %}

<div class="login-page">

    <div class="grid-container">
        <div class="grid-x align-middle login-wrapper">

            <!-- LEFT HERO -->
            <div class="cell small-12 large-6 login-hero">
                <div class="hero-content">
                    <h1>Secret Exchange</h1>
                    <p>
                        Welcome back.  
                        Sign in to manage groups, participants, and drawings.
                    </p>
                </div>
            </div>

            <!-- RIGHT LOGIN -->
            <div class="cell small-12 large-6">

                <div class="callout login-card">

                    <h3 class="text-center">Sign In</h3>

                    {% if error %}
                        <div class="callout alert">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <form action="{{ path('app_login') }}" method="post">

                        <label>
                            Email
                            <input type="text"
                                   name="_username"
                                   value="{{ last_username }}"
                                   required
                                   autofocus>
                        </label>

                        <label>
                            Password
                            <input type="password"
                                   name="_password"
                                   required>
                        </label>

                        <button type="submit" class="button primary expanded">
                            Login
                        </button>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/login.js') }}"></script>
{% endblock %}