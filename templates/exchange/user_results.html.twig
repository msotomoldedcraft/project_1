{% extends 'base.html.twig' %}

{% block title %}
    My Result
    {% if group is defined and group %}
        - {{ group.name }}
    {% endif %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/step6.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-8 large-6">

            <div class="callout text-center">

                <h3>My Draw Result</h3>

                {% if group %}
                    <p>
                        Group: <strong>{{ group.name }}</strong>
                    </p>
                {% endif %}

                <hr>

                {% if user.assignedTo %}

                    <p class="lead">You are giving a gift to:</p>

                    <h4 class="success-text">
                        {{ user.assignedTo.name }}
                    </h4>

                {% else %}

                    <div class="alert callout">
                        <p>Your result is not assigned yet.</p>
                    </div>

                {% endif %}

                <br>

                    <a href="{{ path('exchange_step_6', {'token': user.token}) }}"
                    class="button secondary">
                        Back
                    </a>

            </div>

        </div>

    </div>

</div>

{% endblock %}