{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/intro.css') }}">
{% endblock %}

{% block body %}
<div class="intro-page">

    <!-- HERO SECTION -->
    <section class="intro-hero">

        <div class="hero-overlay"></div>

        <div class="grid-container hero-content">
            <div class="grid-x align-middle align-center text-center full-height">
                <div class="cell small-12 medium-8">

                    <h1 class="hero-title">Secret Exchange</h1>

                    <p class="hero-subtitle">
                        Organize anonymous gift exchanges easily.
                        Create groups, add participants, and let the system handle the rest.
                    </p>

                    {% if is_granted('ROLE_ADMIN') %}

                        <a href="{{ path('admin_dashboard') }}"
                           class="button large hero-btn">
                            Go to Dashboard
                        </a>

                    {% elseif is_granted('ROLE_USER') %}

                        <a href="{{ path('exchange_step_1') }}"
                           class="button large hero-btn">
                            Start Your Wishlist
                        </a>

                    {% else %}

                        <a href="{{ path('app_login') }}"
                           class="button large hero-btn">
                            Start Your Wishlist
                        </a>

                    {% endif %}

                </div>
            </div>
        </div>

    </section>


    <!-- FEATURES SECTION -->
    <section class="intro-section section-cool">

        <div class="grid-container">

            <div class="text-center section-title">
                <h2>Everything You Need</h2>
            </div>

            <!-- Added grid-margin-y for proper mobile spacing -->
            <div class="grid-x grid-margin-x grid-margin-y small-up-1 medium-up-2 large-up-4">

                <div class="cell">
                    <div class="feature-card">
                        <h5>Organize Groups</h5>
                        <p>Create and manage events in seconds.</p>
                    </div>
                </div>

                <div class="cell">
                    <div class="feature-card">
                        <h5>Wishlists</h5>
                        <p>Participants submit gift ideas.</p>
                    </div>
                </div>

                <div class="cell">
                    <div class="feature-card">
                        <h5>Fair Matching</h5>
                        <p>Automatic system prevents self-pairing.</p>
                    </div>
                </div>

                <div class="cell">
                    <div class="feature-card">
                        <h5>Admin Control</h5>
                        <p>Secure tools for full management.</p>
                    </div>
                </div>

            </div>

        </div>

    </section>


    <!-- ABOUT SECTION -->
    <section class="intro-section section-warm">

        <div class="grid-container text-center">

            <h2>About Secret Exchange</h2>

            <p class="about-text">
                Secret Exchange makes gift-giving simple, fun, and completely anonymous.
                Whether you're organizing a holiday exchange with friends, a family surprise,
                or a team event at work, our platform ensures a smooth and stress-free experience.
            </p>

        </div>

    </section>

</div>
{% endblock %}