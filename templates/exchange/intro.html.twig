{% block body %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/intro.css') }}">
{% endblock %}

<div class="intro-paper">

    <!-- HERO SECTION -->
    <section class="hero-wrapper section-slide">
        <div class="hero-card">
            <h1>Welcome to Secret Exchange</h1>
            <p class="hero-sub">Organize fun and anonymous gift exchanges with friends, family, or colleagues — simple, secure, and exciting.</p>
            <a href="{{ path('app_login', { 'redirect': path('exchange_step_1') }) }}" class="btn-primary">Start Your Wishlist</a>
            <div class="scroll-down" onclick="scrollToNext(this)">&#x25BC;</div>
        </div>
    </section>

    <!-- FEATURES SECTION -->
    <section class="features-section section-slide">
        <div class="content-wrapper">
            <h2>Everything You Need</h2>
            <div class="feature-list">
                <div class="feature-item feature-1">
                    <h3>Organize Gift Exchanges</h3>
                    <p>Create groups, invite participants, and manage deadlines effortlessly.</p>
                </div>
                <div class="feature-item feature-2">
                    <h3>Wishlist Management</h3>
                    <p>Each participant adds their wishlist to make gift giving meaningful.</p>
                </div>
                <div class="feature-item feature-3">
                    <h3>Random Matching</h3>
                    <p>Smart system ensures fairness and prevents self-pairing.</p>
                </div>
                <div class="feature-item feature-4">
                    <h3>Admin & Participant Tools</h3>
                    <p>Admins control settings while participants enjoy the surprise.</p>
                </div>
            </div>
        </div>
        <div class="scroll-down" onclick="scrollToNext(this)">&#x25BC;</div>
    </section>

    <!-- ABOUT SECTION -->
    <section class="about-section section-slide">
        <div class="content-wrapper">
            <h2>About Secret Exchange</h2>
            <p>Secret Exchange is designed to make gift-giving easy, fun, and anonymous. Whether it’s for a holiday, birthday, or office event, participants can enjoy the excitement of giving and receiving surprises.</p>
            <p>With a modern and responsive design, Secret Exchange lets users create groups, set up wishlists, and be paired with another participant randomly. The system ensures fairness by preventing anyone from being assigned to themselves.</p>
            <p>Admins have access to secure tools for managing participants, monitoring confirmations, and overseeing gift assignments. Participants can focus on creating thoughtful wishlists while leaving the logistics to the system.</p>
        </div>
        <div class="scroll-down" onclick="scrollToNext(this)">&#x25BC;</div>
    </section>

    <!-- HOW IT WORKS SECTION -->
    <section class="how-section section-slide">
        <div class="content-wrapper">
            <h2>How It Works</h2>
                <p>Create a group and invite participants via email.</p>
                <p>Each participant fills out their wishlist anonymously.</p>
                <p>System randomly assigns recipients while avoiding self-pairing.</p>
                <p>Participants get notified of their recipient securely.</p>
                <p>Exchange gifts and enjoy the surprise!</p>
        </div>
    </section>

    <!-- UP ARROW -->
    <button class="scroll-up" onclick="scrollToTop()">&#x25B2;</button>

</div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/intro.js') }}"></script>
{% endblock %}
