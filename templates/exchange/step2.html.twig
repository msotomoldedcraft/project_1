{% extends 'base.html.twig' %}

{% block title %}Gift Exchange – Step 2{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet"
          href="{{ asset('css/step2.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container step-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-6 large-5">

            <div class="callout step-card">

                <div class="step-header text-center">
                    <h4>Event Setup</h4>
                    <p>
                        Tell us what event you’re organizing.<br>
                        e.g. Christmas Gifts, Valentine’s Day, Birthday Exchange
                    </p>
                </div>

                {{ form_start(form) }}

                    <label>
                        {{ form_label(form.event) }}
                        {{ form_widget(form.event) }}
                        {{ form_errors(form.event) }}
                    </label>

                    <div class="grid-x grid-padding-x align-justify">

                        <div class="cell shrink">
                            <a href="{{ path('exchange_step_1') }}"
                               class="button secondary">
                                ← Back
                            </a>
                        </div>

                        <div class="cell shrink">
                            <button type="submit"
                                    class="button primary">
                                Continue →
                            </button>
                        </div>

                    </div>

                {{ form_end(form) }}

            </div>

        </div>

    </div>

</div>

{% endblock %}