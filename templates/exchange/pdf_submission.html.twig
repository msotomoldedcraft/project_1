<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Secret Exchange Submission</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 14px;
            color: #111;
            margin: 40px;
        }

        h1 {
            text-align: center;
            margin-bottom: 5px;
        }

        hr {
            margin: 20px 0;
        }

        h3 {
            margin-top: 25px;
        }

        ul {
            margin-top: 10px;
        }

        li {
            margin-bottom: 5px;
        }

        .section {
            margin-bottom: 10px;
        }
    </style>

</head>

<body>

    <h1>Secret Exchange Submission</h1>
    <hr>

    <div class="section">
        <strong>Name:</strong> {{ user.name }}
    </div>

    <div class="section">
        <strong>Email:</strong> {{ user.email }}
    </div>

    <div class="section">
        <strong>Event:</strong> {{ group ? group.name : 'N/A' }}
    </div>

    <h3>Wishlist Items:</h3>

    <ul>
        {% if wishlist|length > 0 %}
            {% for item in wishlist %}
                <li>{{ item.name }}</li>
            {% endfor %}
        {% else %}
            <li>No wishlist items added.</li>
        {% endif %}
    </ul>

</body>
</html>