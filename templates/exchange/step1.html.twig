{% extends 'base.html.twig' %}

{% block title %}Gift Exchange – Step 1{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/step1.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container step-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-6 large-5">

            <div class="callout step-card">

                <div class="text-center step-header">
                    <h1>Your Information</h1>
                    <p>
                        Enter your details to continue setting up your participation.
                    </p>
                </div>

                {{ form_start(form) }}

                <label>
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name, {
                        'attr': {'class': 'input-field'}
                    }) }}
                    {{ form_errors(form.name) }}
                </label>

                <label>
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {
                        'attr': {'class': 'input-field'}
                    }) }}
                    {{ form_errors(form.email) }}
                </label>

                <div class="step-actions">
                    <button type="submit" class="button primary expanded">
                        Continue
                    </button>
                </div>

                {{ form_end(form) }}

            </div>

        </div>

    </div>

</div>

{% endblock %}