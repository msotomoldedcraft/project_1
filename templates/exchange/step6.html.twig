{% extends 'base.html.twig' %}

{% block title %}Welcome{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/step6.css') }}">
{% endblock %}

{% block body %}

<div class="step6-wrapper">

    <div class="grid-container">

        <div class="grid-x align-center">

            <div class="cell small-12 medium-9 large-7">

                <div class="welcome-card">

                    <div class="welcome-header text-center">
                        <h2>Welcome, {{ user.name }}</h2>

                        <p>
                            You are confirmed for
                            <strong>{{ group ? group.name : 'your event' }}</strong>.
                        </p>
                    </div>

                    <div class="welcome-actions">

                        <a href="{{ path('wishlist_edit', {'token': user.token}) }}"
                           class="button primary expanded">
                            Edit Wishlist
                        </a>

                        <a href="{{ path('exchange_download', {'token': user.token}) }}"
                           class="button secondary expanded">
                            Download PDF
                        </a>

                        <a href="{{ path('group_results') }}"
                           class="button secondary expanded">
                            View Results
                        </a>

                        {% if is_granted('ROLE_ADMIN') and group %}
                            <a href="{{ path('admin_draw_names', {'groupId': group.id}) }}"
                               class="button success expanded">
                                Draw Names (Admin)
                            </a>
                        {% endif %}

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}