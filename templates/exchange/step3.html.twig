{% extends 'base.html.twig' %}

{% block title %}Gift Exchange – Step 3{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet"
          href="{{ asset('css/step3.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container step-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-8 large-6">

            <div class="callout step-card">

                <h3 class="text-center">Your Wishlist</h3>

                <p class="text-center">
                    Add the items you would like to receive.<br>
                    You can add as many as you want!
                </p>

                {{ form_start(form) }}

                <div id="wishlist-items"
                     data-prototype="{{ form_widget(form.wishlist.vars.prototype)|e('html_attr') }}">

                    {% for item in form.wishlist %}
                        <div class="grid-x align-middle wishlist-item">
                            <div class="cell auto">
                                {{ form_widget(item) }}
                            </div>

                            <div class="cell shrink">
                                <button type="button"
                                        class="button alert small remove-wishlist">
                                    Remove
                                </button>
                            </div>
                        </div>
                    {% endfor %}

                </div>

                <button type="button"
                        id="add-wishlist-item"
                        class="button hollow primary margin-top-1">
                    + Add Item
                </button>

                <hr>

                <div class="grid-x align-justify">

                    <div class="cell shrink">
                        <a href="{{ path('exchange_step_2') }}"
                           class="button secondary">
                            ← Back
                        </a>
                    </div>

                    <div class="cell shrink">
                        <button type="submit"
                                class="button success">
                            Continue →
                        </button>
                    </div>

                </div>

                {{ form_end(form) }}

            </div>

        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/wishlist.js') }}"></script>
{% endblock %}