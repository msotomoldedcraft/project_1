{% extends 'base.html.twig' %}

{% block title %}Edit Your Wishlist{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/edit_wishlist.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container step-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-8 large-6">

            <div class="callout wishlist-card">

                <h3 class="text-center">Edit Your Wishlist</h3>

                {{ form_start(form) }}

                {# Collection Container #}
                <div id="wishlist-items"
                     data-prototype="{{ form_widget(form.wishlist.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.wishlist|length }}">

                    {% for item in form.wishlist %}
                        <div class="grid-x align-middle wishlist-item">

                            <div class="cell auto">
                                {{ form_widget(item) }}
                            </div>

                            <div class="cell shrink">
                                <button type="button"
                                        class="button alert small remove-wishlist">
                                    Remove
                                </button>
                            </div>

                        </div>
                    {% endfor %}

                </div>

                {# Add Button #}
                <button type="button"
                        id="add-wishlist-item"
                        class="button add-item-btn">
                    + Add Item
                </button>

                <hr>

                <div class="grid-x align-justify action-buttons">

                    <div class="cell shrink">
                        <button type="submit"
                                class="button primary">
                            Update Wishlist
                        </button>
                    </div>

                    <div class="cell shrink">
                        <a href="{{ path('exchange_step_6', {'token': user.token}) }}"
                           class="button secondary">
                            Cancel
                        </a>
                    </div>

                </div>

                {{ form_end(form) }}

            </div>

        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/wishlist.js') }}"></script>
{% endblock %}