{% extends 'base.html.twig' %}

{% block title %}Step 4 – Confirmation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet"
          href="{{ asset('css/step4.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container step-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-8 large-6">

            <div class="callout step-card">

                <h3 class="text-center">Step 4: Confirm Your Details</h3>

                <p class="text-center">
                    Please review your input before sending the verification email.
                </p>

                <!-- Details -->
                <ul class="no-bullet">
                    <li><strong>Name:</strong> {{ data.name }}</li>
                    <li><strong>Email:</strong> {{ data.email }}</li>
                    <li><strong>Event:</strong> {{ data.event }}</li>
                    <li>
                        <strong>Wishlist:</strong>

                        <ul>
                            {% for item in data.wishlist %}
                                <li>{{ item }}</li>
                            {% else %}
                                <li>No wishlist items added.</li>
                            {% endfor %}
                        </ul>

                    </li>
                </ul>

                <hr>

                <div class="grid-x align-justify">

                    <div class="cell shrink">
                        <a href="{{ path('exchange_step_3') }}"
                           class="button secondary">
                            ← Back
                        </a>
                    </div>

                    <div class="cell shrink">

                        <form method="post"
                              action="{{ path('exchange_step_4_submit') }}">

                            <button type="submit"
                                    class="button success">
                                Confirm & Send Verification
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/step4.js') }}"></script>
{% endblock %}