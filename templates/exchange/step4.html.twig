{% extends 'base.html.twig' %}

{% block title %}Step 4 – Confirmation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/step4.css') }}">
{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="card shadow-lg p-5 mx-auto confirmation-card">
        <h1 class="mb-4 text-center">Step 4: Confirm Your Details</h1>

        <p class="text-center text-muted mb-4">
            Please review your input before sending the verification email.
        </p>

        <ul class="list-group mb-4">
            <li class="list-group-item"><strong>Name:</strong> {{ data.name }}</li>
            <li class="list-group-item"><strong>Email:</strong> {{ data.email }}</li>
            <li class="list-group-item"><strong>Event:</strong> {{ data.event }}</li>
            <li class="list-group-item">
                <strong>Wishlist:</strong>
                <ul class="mt-2">
                    {% for item in data.wishlist %}
                        <li>{{ item }}</li>
                    {% else %}
                        <li>No wishlist items added.</li>
                    {% endfor %}
                </ul>
            </li>
        </ul>

        <div class="d-flex justify-content-between">
            <a href="{{ path('exchange_step_3') }}" class="btn btn-secondary btn-lg">
                ← Back
            </a>

            <form method="post" action="{{ path('exchange_step_4_submit') }}">
                <button class="btn btn-success btn-lg">
                    Confirm & Send Verification
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/step4.js') }}"></script>
{% endblock %}
