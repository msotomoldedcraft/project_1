{% extends 'base.html.twig' %}

{% block title %}Email Verification{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/step5.css') }}">
{% endblock %}

{% block body %}

<div class="grid-container step-container">

    <div class="grid-x align-center">

        <div class="cell small-12 medium-8 large-6">

            <div class="callout verification-card text-center">

                <h3>Submission Completed</h3>

                <p class="lead">
                    Please check your email for confirmation.
                    If you didn’t receive it, you may resend it below.
                </p>

                {# FLASH SUCCESS #}
                {% for message in app.flashes('success') %}
                    <div class="callout success">
                        {{ message }}
                    </div>
                {% endfor %}

                {# FLASH ERROR #}
                {% for message in app.flashes('error') %}
                    <div class="callout alert">
                        {{ message }}
                    </div>
                {% endfor %}

                <div class="grid-x grid-padding-x align-center">

                    {# RESEND BUTTON #}
                    <div class="cell shrink">

                        <form method="post"
                              action="{{ path('exchange_step_5_resend') }}"
                              class="resend-form">

                            <input type="hidden"
                                   name="email"
                                   value="{{ user.email }}">

                            <button type="submit"
                                    id="resendBtn"
                                    class="button primary"
                                    disabled>
                                Send Again
                            </button>

                            {# PROGRESS BAR #}
                            <div class="progress-container">
                                <div id="progress" class="progress-bar"></div>
                            </div>

                        </form>

                    </div>

                    {# CONFIRM BUTTON #}
                    <div class="cell shrink">
                        <a href="{{ path('exchange_confirm', {'token': user.token}) }}"
                           class="button success">
                            Confirm
                        </a>
                    </div>

                    {# NEW WISHLIST #}
                    <div class="cell shrink">
                        <a href="{{ path('exchange_step_1') }}"
                           class="button secondary">
                            Create New Wishlist
                        </a>
                    </div>

                </div>

                <p class="text-muted">
                    You can resend the email after
                    <span id="countdown">5</span> seconds.
                </p>

            </div>

        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/step5.js') }}"></script>
{% endblock %}