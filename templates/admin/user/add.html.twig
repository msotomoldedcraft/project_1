{% extends 'base.html.twig' %}

{% block title %}Add Participant{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin_add.css') }}">
{% endblock %}

{% block body %}

<div class="admin-add-background">

    <div class="grid-container admin-add-container">

        <div class="grid-x align-center">

            <div class="cell small-12 medium-8">

                <h2>Add Participant</h2>
                <p>Adding to group: <strong>{{ group.name }}</strong></p>

                <div class="callout">

                    <form method="post" id="participant-form">

                        <!-- NAME -->
                        <label>Name
                            <input type="text" name="name" required>
                        </label>

                        <!-- EMAIL -->
                        <label>Email
                            <input type="email" name="email" required>
                        </label>

                        <hr>

                        <!-- WISHLIST -->
                        <h4>Wishlist</h4>
                        <p class="help-text">
                            Add as many wishlist items as needed
                        </p>

                        <div id="wishlist-container">

                            <div class="grid-x grid-margin-x align-middle wishlist-item">
                                <div class="cell auto">
                                    <input type="text" name="wishlist[]" placeholder="Wishlist item">
                                </div>
                                <div class="cell shrink">
                                    <button type="button"
                                            class="button alert tiny remove-btn">
                                        ×
                                    </button>
                                </div>
                            </div>

                        </div>

                        <button type="button"
                                class="button secondary"
                                id="add-wishlist-btn">
                            + Add another wishlist item
                        </button>

                        <hr>

                        <!-- ACTIONS -->
                        <div class="grid-x grid-margin-x">

                            <div class="cell auto">
                                <button type="submit"
                                        class="button success expanded">
                                    Add Participant
                                </button>
                            </div>

                            <div class="cell auto">
                                <a href="{{ path('admin_dashboard') }}"
                                   class="button secondary expanded">
                                    Cancel
                                </a>
                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/admin_add.js') }}"></script>
{% endblock %}