{% extends 'base.html.twig' %}

{% block title %}Edit Participant{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/admin_edit.css') }}">
{% endblock %}

{% block body %}

<div class="edit-container">

    <!-- Header -->
    <div class="edit-header">
        <div>
            <h1>Edit Participant</h1>
            <p>Update participant details and manage wishlist items</p>
        </div>
        <a href="{{ path('admin_dashboard') }}" class="btn-secondary">
            Back to Dashboard
        </a>
    </div>

    <!-- Card -->
    <div class="edit-card">
        <form method="post">

            <!-- Basic Info -->
            <div class="form-section">
                <h3>Participant Information</h3>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Name</label>
                        <input name="name" value="{{ user.name }}" required>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input name="email" value="{{ user.email }}" required>
                    </div>
                </div>
            </div>

            <!-- Wishlist Section -->
            <div class="form-section">
                <h3>Wishlist</h3>
                <p class="section-muted">Edit, remove, or add wishlist items</p>

                <div class="wishlist-container">

                    {% if user.wishlist|length > 0 %}
                        {% for wish in user.wishlist %}
                            <div class="wishlist-item">
                                <input
                                    name="wishlist_existing[{{ wish.id }}]"
                                    value="{{ wish.name }}"
                                >
                                <button type="button"
                                        class="remove-btn"
                                        onclick="removeWishlistItem(this)">
                                    Remove
                                </button>
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="empty-state">No wishlist items yet</p>
                    {% endif %}

                </div>

                <div id="new-wishlist-container"></div>

                <button type="button"
                        class="btn-outline"
                        onclick="addNewWishlist()">
                    + Add New Wishlist Item
                </button>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button class="btn-primary">
                    Save Changes
                </button>
                <a href="{{ path('admin_dashboard') }}"
                   class="btn-secondary">
                    Cancel
                </a>
            </div>

        </form>
    </div>

</div>

<script src="{{ asset('js/admin_edit.js') }}"></script>

{% endblock %}