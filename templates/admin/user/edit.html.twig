{% extends 'base.html.twig' %}

{% block title %}Edit Participant{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin_edit.css') }}">
{% endblock %}

{% block body %}

<div class="admin-edit-background">

    <div class="grid-container edit-container">

        <div class="grid-x align-center">

            <div class="cell small-12 medium-8">

                <h2>Edit Participant</h2>
                <p>Updating: <strong>{{ user.name }}</strong></p>

                <div class="callout">

                    <form method="post">

                        <!-- PARTICIPANT INFO -->
                        <h4>Participant Information</h4>

                        <label>Name
                            <input type="text"
                                   name="name"
                                   value="{{ user.name }}"
                                   required>
                        </label>

                        <label>Email
                            <input type="email"
                                   name="email"
                                   value="{{ user.email }}"
                                   required>
                        </label>

                        <hr>

                        <!-- WISHLIST -->
                        <h4>Wishlist</h4>
                        <p class="help-text">
                            Edit or remove existing items, or add new ones
                        </p>

                        <div id="wishlist-container">

                            {% for wish in user.wishlist %}
                                <div class="grid-x grid-margin-x align-middle wishlist-item">
                                    <div class="cell auto">
                                        <input type="text"
                                               name="wishlist_existing[{{ wish.id }}]"
                                               value="{{ wish.name }}">
                                    </div>
                                    <div class="cell shrink">
                                        <button type="button"
                                                class="button alert tiny"
                                                onclick="removeWishlistItem(this)">
                                            ×
                                        </button>
                                    </div>
                                </div>
                            {% else %}
                                <p class="empty-state">No wishlist items yet</p>
                            {% endfor %}

                        </div>

                        <div id="new-wishlist-container"></div>

                        <button type="button"
                                class="button secondary"
                                onclick="addNewWishlist()">
                            + Add another wishlist item
                        </button>

                        <hr>

                        <!-- ACTIONS -->
                        <div class="grid-x grid-margin-x">

                            <div class="cell auto">
                                <button type="submit"
                                        class="button success expanded">
                                    Save Changes
                                </button>
                            </div>

                            <div class="cell auto">
                                <a href="{{ path('admin_dashboard') }}"
                                   class="button secondary expanded">
                                    Cancel
                                </a>
                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/admin_edit.js') }}"></script>
{% endblock %}