<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Secret Exchange{% endblock %}</title>

    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22></text></svg>">

    <!-- Foundation CSS -->
    <link rel="stylesheet" href="{{ asset('css/foundation.min.css') }}">

    <!-- Global CSS -->
    <link rel="stylesheet" href="{{ asset('css/main.css') }}">

    {% block stylesheets %}{% endblock %}
</head>

<body>

<div class="off-canvas-wrapper">

    <!-- Offcanvas Menu -->
    <div class="off-canvas position-right" id="offCanvas" data-off-canvas>

        <ul class="vertical menu offcanvas-menu">

            {% if app.user %}
                <li class="menu-user">
                    Logged in as<br>
                    <strong>{{ app.user.email }}</strong>
                </li>
                <li><a href="{{ path('app_logout') }}">Logout</a></li>
            {% else %}
                <li><a href="{{ path('app_login') }}">Login</a></li>
            {% endif %}

        </ul>

    </div>

    <!-- Main Content -->
    <div class="off-canvas-content" data-off-canvas-content>

        <!-- Header -->
        <header class="custom-header">

            <div class="header-left">
                <a href="{{ path('exchange_intro') }}" class="site-title">
                    Secret Exchange
                </a>
            </div>

            <div class="header-right">

                <div class="login-indicator">
                    {% if app.user %}
                        <span class="status logged-in">● Online</span>
                    {% else %}
                        <span class="status logged-out">● Guest</span>
                    {% endif %}
                </div>

                <button class="menu-icon"
                        type="button"
                        data-toggle="offCanvas">
                </button>

            </div>

        </header>

        <!-- Page Content -->
        <main>
            {% block body %}{% endblock %}
        </main>

        <!-- Footer -->
        <footer class="site-footer">
            <div class="grid-container text-center">
                <p>
                    © {{ "now"|date("Y") }} Secret Exchange.
                    All rights reserved.
                </p>
            </div>
        </footer>

    </div>
</div>

<!-- jQuery -->
<script src="https://cdn.jsdelivr.net/npm/jquery/dist/jquery.min.js"></script>

<!-- Foundation JS -->
<script src="{{ asset('js/foundation.min.js') }}"></script>

<script>
    $(document).foundation();
</script>

{% block javascripts %}{% endblock %}

</body>
</html>