{# templates/emails/exchange_confirmation.html.twig #}
<table width="100%" cellpadding="0" cellspacing="0" style="font-family:Arial,sans-serif; background:#f7f7f7; padding:20px;">
    <tr>
        <td align="center">
            <table width="600" cellpadding="0" cellspacing="0" style="background:white; border-radius:10px; padding:30px; box-shadow:0 0 10px rgba(0,0,0,0.1);">
                <tr>
                    <td style="text-align:center; padding-bottom:20px;">
                        <h1 style="color:#28a745; font-size:24px; margin:0;">🎁 Secret Exchange Confirmation</h1>
                    </td>
                </tr>

                <tr>
                    <td style="padding-bottom:20px; text-align:center;">
                        <p style="font-size:16px; color:#555;">
                            Hi <strong>{{ user.name }}</strong>,
                        </p>
                        <p style="font-size:16px; color:#555;">
                            Your submission for <strong>{{ event }}</strong> has been successfully recorded.
                        </p>
                    </td>
                </tr>

                <tr>
                    <td style="padding-bottom:20px; text-align:center;">
                        <p style="font-size:16px; color:#555; margin-bottom:10px;">Download your submission (PDF):</p>
                        <a href="{{ downloadUrl }}" style="display:inline-block; padding:12px 24px; background:#007bff; color:white; text-decoration:none; border-radius:6px; font-weight:bold;">
                            Download PDF
                        </a>
                    </td>
                </tr>

                {% if wishlistItems is defined and wishlistItems|length > 0 %}
                <tr>
                    <td style="padding-bottom:20px;">
                        <p style="font-size:16px; color:#555; font-weight:bold; margin-bottom:5px;">Your Wishlist:</p>
                        <ul style="font-size:16px; color:#555; padding-left:20px; margin:0;">
                            {% for item in wishlistItems %}
                                <li>{{ item }}</li>
                            {% endfor %}
                        </ul>
                    </td>
                </tr>
                {% endif %}

                <tr>
                    <td style="text-align:center; padding-top:20px; border-top:1px solid #eee;">
                        <p style="font-size:14px; color:#999; margin:0;">Thank you for participating! 🎁</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
